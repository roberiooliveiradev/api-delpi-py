# Banco de Dados (SQL Server / TOTVS Protheus)
DB_HOST=seu_host_aqui
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_DATABASE=nome_do_banco
DB_PORT=1433

# API
PORT=8000
JWT_SECRET=troque_por_uma_chave_segura

# Configurações do Agente GPT
AUTO_EXECUTE_API=true
CONFIRM_BEFORE_REQUEST=false
SHOW_PAYLOAD_BEFORE_EXECUTE=false
